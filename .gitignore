# Ignore cache and temporary files
.cache/
.thumbnails/
*.log
*.tmp

# Ignore Matugen generated colors/themes
**/colors.css
**/colors.rasi
**/theme.toml
# starship prompt
**/starship.toml
# dunst notifications
**/dunstrc
# gtk
**/gtk.css
**/gtk-dark.css
# Ignore Kitty's active theme state
**/colors.conf
**/current-theme.conf
# Ignore active wallpaper symlink
**/current_wall
lazy-lock.json

# Ignore all of Calibre's dynamic data
calibre/.config/calibre/**/*

# Allow the actual Rice and Config files
!calibre/.config/calibre/gui.json
!calibre/.config/calibre/gui.py.json
!calibre/.config/calibre/global.py.json
!calibre/.config/calibre/customize.py.json
!calibre/.config/calibre/viewer-webengine.json

# Ignore the viewer's history/annotation folder specifically
calibre/.config/calibre/viewer/annots/
