[global]
monitor = 0
    follow = mouse
    
    # New syntax for width and height: (min, max)
    # Using (0, 300) mimics the old behavior (dynamic height up to 300)
    width = (0, 300)
    height = (0, 300)
    
    origin = top-right
    
    # New syntax for offset: (horizontal, vertical)
    offset = (20, 20)
    
    scale = 0
    notification_limit = 5
    
    # Progress Bar
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    
    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 10
    horizontal_padding = 10
    text_icon_padding = 10
    frame_width = 2
    
    # Layout
    frame_color = "#c2c1ff"
    separator_color = frame
    sort = yes
    idle_threshold = 120
    
    # Text
    font = JetBrains Mono Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    stack_duplicates = true
    hide_duplicate_count = false
    
    # Icons
    show_indicators = yes
    icon_position = left
    min_icon_size = 0
    max_icon_size = 64
    
    # History
    sticky_history = yes
    history_length = 20
    
    # Misc
    dmenu = /usr/bin/rofi -dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 12

[urgency_low]
    background = "#1b1b21e6"
    foreground = "#e5e1e9"
    frame_color = "#918f9a"
    timeout = 5

[urgency_normal]
    background = "#1f1f25e6"
    foreground = "#e5e1e9"
    frame_color = "#c2c1ff"
    timeout = 10

[urgency_critical]
    background = "#2a292fe6"
    foreground = "#e5e1e9"
    frame_color = "#ffb4ab"
    timeout = 0
